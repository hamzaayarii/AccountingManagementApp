pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                git branch: 'dev', url: 'https://github.com/hamzaayarii/AccountingManagementApp.git'
            }
        }

        stage('Debug: List Files') {
            steps {
                sh 'ls -la'  // Check repo structure
            }
        }

        stage('Verify Node.js & npm') {
            steps {
                sh 'node -v && npm -v'  // Ensure Node.js is installed
            }
        }

        stage('Install Dependencies') {
            steps {
                script {
                    if (fileExists('backend/package.json')) {
                        dir('backend') {
                            sh 'npm install'
                        }
                    } else {
                        error "backend/package.json not found!"
                    }
                }
            }
        }

        stage('Run Tests') {
            steps {
                dir('backend') {
                    sh 'npm test'
                }
            }
        }
    }  
}
