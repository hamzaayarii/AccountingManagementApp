pipeline {
    agent any

    environment {
        GIT_CREDENTIALS_ID = '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'
    }

    stages {
        stage('Checkout Code') {
            steps {
                script {
                    checkout([
                        $class: 'GitSCM',
                        branches: [[name: 'dev']],  // Ensure dev branch is checked out
                        userRemoteConfigs: [[
                            url: 'https://github.com/hamzaayarii/AccountingManagementApp.git',
                            credentialsId: GIT_CREDENTIALS_ID
                        ]]
                    ])
                }
            }
        }

        stage('Install Dependencies') {
            steps {
                // Navigate to the backend folder before installing dependencies
                dir('backend') {
                    sh 'npm install'
                }
            }
        }

        stage('Run Unit Tests') {
            steps {
                // Navigate to the backend folder before running tests
                dir('backend') {
                    sh 'npm test'
                }
            }
        }

        stage('Build Application') {
            steps {
                // Navigate to the backend folder before building the application
                dir('backend') {
                    sh 'npm run build'
                }
            }
        }
    }
}
