pipeline {
    agent any

    environment {
        GIT_CREDENTIALS_ID = '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'
    }

    stages {
        stage('Checkout Code') {
            steps {
                script {
                    checkout([
                        $class: 'GitSCM',
                        branches: [[name: '**']],  // Fetch all branches
                        userRemoteConfigs: [[
                            url: 'https://github.com/hamzaayarii/AccountingManagementApp.git',
                            credentialsId: GIT_CREDENTIALS_ID
                        ]]
                    ])
                }
            }
        }

        stage('Install Dependencies') {
            steps {
                sh 'npm install'
            }
        }

        stage('Run Unit Tests') {
            steps {
                sh 'npm test'
            }
        }

        stage('Build Application') {
            steps {
                sh 'npm run build'
            }
        }
    }
}